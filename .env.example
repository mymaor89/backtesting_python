# Copy to .env and fill in the values before running docker compose up.

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_in_production

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_in_production

# ── Data ingestor ─────────────────────────────────────────────────────────────
# Comma-separated list of symbols to ingest.
# Format: EXCHANGE:SYMBOL:YFINANCE_TICKER:INTERVAL
# INGEST_SYMBOLS=yfinance:BTCUSD:BTC-USD:1h,yfinance:ETHUSD:ETH-USD:1h,yfinance:SPY:SPY:1d

# How often the ingestor polls for new bars (seconds)
# INGESTOR_POLL_INTERVAL=300

# ── Celery ────────────────────────────────────────────────────────────────────
# Override only if you point Redis at a different host/db
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Go backend (placeholder) ──────────────────────────────────────────────────
# The Go service can reach the Python API at http://api-gateway:8000
# Set this in your Go service environment:
# STRATEGY_ENGINE_URL=http://api-gateway:8000
